# Copier vers .env à la racine de mon-api, puis redémarrer Spring Boot.
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs (Web application)
GOOGLE_CLIENT_ID=133671696747-vm4qm6fmbl8rul31pb42lcbpr089n0m1.apps.googleusercontent.com

# Origines autorisées dans Google Cloud Console :
#   http://localhost:4200
#   http://127.0.0.1:4200

APP_FRONTEND_URL=http://localhost:4200
APP_API_PUBLIC_URL=http://127.0.0.1:8080

# Optionnel — sans SMTP, les liens de vérification email apparaissent dans les logs Spring.
# Exemple Gmail : utilisez un "App password", pas votre mot de passe Google normal.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-google-app-password
# MAIL_FROM=your-email@gmail.com
